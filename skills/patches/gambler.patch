--- /dev/null
+++ b/src/game/skill_gambler.v
@@ -0,0 +1,49 @@
+`timescale 1ns / 1ps
+
+module skill_gambler #(
+	parameter DURATION = 10,
+	parameter CHARGE_MAX = 5
+)(
+	input clk,
+	input resetn,
+	input tick,
+	input restart,
+	input btn_skill,
+	input [2:0] skill_charge,
+
+	output reg [7:0] skill_timer,
+	output gambler_on,
+	output start_pulse
+);
+reg [5:0] sec_cnt;
+reg btn_q;
+
+assign gambler_on = skill_timer != 0;
+assign start_pulse = btn_skill && !btn_q && skill_charge >= CHARGE_MAX && !gambler_on;
+
+always @(posedge clk) begin
+	if (!resetn) begin
+		skill_timer <= 0;
+		sec_cnt <= 0;
+		btn_q <= 0;
+	end else if (restart) begin
+		skill_timer <= 0;
+		sec_cnt <= 0;
+		btn_q <= 0;
+	end else begin
+		btn_q <= btn_skill;
+
+		if (start_pulse) begin
+			skill_timer <= DURATION;
+			sec_cnt <= 0;
+		end else if (tick && skill_timer != 0) begin
+			if (sec_cnt == 59) begin
+				sec_cnt <= 0;
+				skill_timer <= skill_timer - 1;
+			end else begin
+				sec_cnt <= sec_cnt + 1;
+			end
+		end
+	end
+end
+endmodule
